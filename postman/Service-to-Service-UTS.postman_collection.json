            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { users(limit: 5) { id name email } foods(limit: 5) { id name price qty } orders(limit: 5) { id user_id food_id quantity total_price status } }\"\n}"
            }
