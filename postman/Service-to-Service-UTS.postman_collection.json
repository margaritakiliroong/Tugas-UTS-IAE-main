        {
          "name": "Create Order via REST Async",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "const jsonData = pm.response.json();",
                  "pm.test('Order starts as pending', function () { pm.expect(jsonData.status).to.eql('pending'); });",
                  "if (jsonData.id) pm.collectionVariables.set('order_id', jsonData.id);"
                ]
              }
            }
